{
  "info": {
    "name": "Support Ticket API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"amit@example.com\",\n  \"password\": \"password\",\n  \"deviceName\": \"Angular\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/auth/logout"
      }
    },
    {
      "name": "List tickets",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/support/tickets?search=claim&queue=Portal%20Support&priority=High&status=Open&page=1&pageSize=20&sort=updated_desc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "support",
            "tickets"
          ],
          "query": [
            {
              "key": "search",
              "value": "claim"
            },
            {
              "key": "queue",
              "value": "Portal Support"
            },
            {
              "key": "priority",
              "value": "High"
            },
            {
              "key": "status",
              "value": "Open"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "20"
            },
            {
              "key": "sort",
              "value": "updated_desc"
            }
          ]
        }
      }
    },
    {
      "name": "Create ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subject\": \"New portal error\",\n  \"customer\": \"HLIB\",\n  \"requester\": \"Nur Aisyah\",\n  \"team\": \"Portal Support\",\n  \"category\": \"Portal / Error\",\n  \"priority\": \"High\",\n  \"message\": \"Please check this issue.\",\n  \"attachmentIds\": [\"ATT-2001\"]\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets"
      }
    },
    {
      "name": "List attachments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/attachments?search=claim&visibility=public&page=1&pageSize=20"
      }
    },
    {
      "name": "Upload attachment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": []
            },
            {
              "key": "visibility",
              "value": "public",
              "type": "text"
            },
            {
              "key": "ticketId",
              "value": "TK-1048",
              "type": "text"
            },
            {
              "key": "customer",
              "value": "HLIB",
              "type": "text"
            },
            {
              "key": "requester",
              "value": "Amit",
              "type": "text"
            }
          ]
        },
        "url": "{{baseUrl}}/api/support/attachments/upload"
      }
    },
    {
      "name": "Get support reference data",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/reference-data"
      }
    },
    {
      "name": "Get support teams",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/teams"
      }
    },
    {
      "name": "Get support categories",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/categories"
      }
    },
    {
      "name": "Get support agents",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/agents"
      }
    },
    {
      "name": "Get ticket detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/tickets/TK-1048"
      }
    },
    {
      "name": "Get linked tasks",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/linked-tasks"
      }
    },
    {
      "name": "Get ticket attachments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/attachments"
      }
    },
    {
      "name": "Bulk assign",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ticketIds\": [\"TK-1048\", \"TK-1047\"],\n  \"agent\": \"Amit\"\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/bulk/assign"
      }
    },
    {
      "name": "Bulk status",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ticketIds\": [\"TK-1048\", \"TK-1047\"],\n  \"status\": \"In Progress\"\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/bulk/status"
      }
    },
    {
      "name": "Bulk priority",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ticketIds\": [\"TK-1048\", \"TK-1047\"],\n  \"priority\": \"High\"\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/bulk/priority"
      }
    },
    {
      "name": "Reply to ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hi @arka please verify.\",\n  \"isInternalNote\": false,\n  \"attachmentIds\": [\"ATT-1001\"],\n  \"parentActivityId\": \"ACT-9001\",\n  \"mentions\": [\n    {\n      \"id\": \"user_44\",\n      \"kind\": \"user\",\n      \"display\": \"arka\"\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/reply"
      }
    },
    {
      "name": "Forward ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"external\",\n  \"to\": \"recipient@example.com\",\n  \"comment\": \"Please review the attachment workflow.\",\n  \"includeAttachments\": true,\n  \"attachmentIds\": [\"ATT-1001\", \"ATT-1002\"]\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/forward"
      }
    },
    {
      "name": "Forward ticket to team",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"team\",\n  \"teamId\": \"portal-support\",\n  \"comment\": \"Please take over this case.\"\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/forward"
      }
    },
    {
      "name": "Forward ticket as linked task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"task\",\n  \"createLinkedTask\": true,\n  \"taskTitle\": \"Review attachment workflow\",\n  \"taskAssignee\": \"Amit\",\n  \"comment\": \"Please review this flow.\",\n  \"attachmentIds\": [\"ATT-1001\"]\n}"
        },
        "url": "{{baseUrl}}/api/support/tickets/TK-1048/forward"
      }
    }
  ]
}
